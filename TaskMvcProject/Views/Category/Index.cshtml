@model IEnumerable<TaskMvcProject.Models.Category>

@{
    ViewData["Title"] = "Category Management";
}

<style>
    body {
        background-color: #0f172a !important;
        color: #f1f5f9 !important;
    }

    .category-card {
        background: linear-gradient(145deg, #1e293b, #0f172a);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 15px;
    }

    .category-input {
        background-color: #1e293b !important;
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
        color: #ffffff !important;
        border-radius: 10px;
    }

        .category-input:focus {
            background-color: #1e293b !important;
            color: #ffffff !important;
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25) !important;
        }

    .category-item {
        background-color: #1e293b;
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        transition: all 0.2s ease;
    }

        .category-item:hover {
            transform: translateY(-2px);
            background-color: #24344d;
        }
</style>

<div class="container mt-4" style="max-width: 700px;">
    <h3 class="fw-bold text-white mb-4">📁 Category Management</h3>

    <div class="category-card p-4 mb-4 shadow-lg">
        <form asp-action="Create" method="post" class="row g-2 align-items-center">
            <div class="col-sm-9">
                <input type="text" name="Name" class="form-control category-input" placeholder="Enter new category name..." required />
            </div>
            <div class="col-sm-3">
                <button type="submit" class="btn btn-primary w-100 fw-bold" style="border-radius: 10px; background-color: #3b82f6; border: none; height: 38px;">+ Add</button>
            </div>
        </form>
    </div>

    <div class="d-flex flex-column gap-2">
        @if (!Model.Any())
        {
            <div class="text-muted text-center py-4">No categories found. Add one above!</div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="category-item p-3 d-flex align-items-center justify-content-between shadow-sm">
                    <div class="d-flex align-items-center gap-3">
                        <span class="fs-5">📁</span>
                        <span class="fw-semibold text-white">@item.Name</span>
                    </div>
                    <div>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this category?');" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-link text-danger p-1"><span class="fs-5">🗑️</span></button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>