@model TaskMvcProject.Models.User
@{
    ViewData["Title"] = "Login";
}
<style>
    body {
        background-color: #0f172a !important;
        color: #f1f5f9 !important;
    }

    .auth-card {
        background-color: #1e293b !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        border-radius: 15px;
        max-width: 400px;
        margin: auto;
    }

    .custom-alert-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .custom-alert-box {
        background-color: #1e293b;
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 25px;
        border-radius: 12px;
        text-align: center;
        max-width: 350px;
        width: 90%;
        box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    }
</style>

@* *@
@if (TempData["LoginFailed"] != null)
{
    <div class="custom-alert-overlay" id="myAlertBox">
        <div class="custom-alert-box">
            <h4 class="text-danger fw-bold mb-2">❌ Login Failed!</h4>
            <p class="text-muted small mb-4">Login Fail ဖြစ်သွားပါသဖြင့် ပြန်လည်စစ်ဆေးပေးပါရန်။</p>
            <button type="button" class="btn btn-primary w-100 fw-bold" onclick="closeAlert()" style="border-radius: 8px; background-color: #3b82f6; border: none;">OK</button>
        </div>
    </div>
}

@* *@
@if (TempData["RegisterSuccess"] != null)
{
    <div class="custom-alert-overlay" id="myRegisterAlertBox">
        <div class="custom-alert-box">
            <h4 class="text-success fw-bold mb-2">🎉 Register Success!</h4>
            <p class="text-muted small mb-4">Account Register လုပ်ခြင်း အောင်မြင်ပါသည်။ သို့သော် Admin ၏ Confirm ပြုလုပ်မှုကို စောင့်ဆိုင်းပေးရပါမည်။</p>
            <button type="button" class="btn btn-primary w-100 fw-bold" onclick="closeRegisterAlert()" style="border-radius: 8px; background-color: #3b82f6; border: none;">OK</button>
        </div>
    </div>
}

<div class="container mt-5">
    <div class="card auth-card p-4 shadow-lg">
        <h3 class="fw-bold text-center text-white mb-3">🔑 Welcome Back</h3>
        <p class="text-muted text-center small mb-4">Log in to manage your daily tasks effectively.</p>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label small text-muted">Email Address</label>
                <input type="text"
                       asp-for="Email"
                       class="form-control text-white"
                       placeholder="e.g., test@gmail.com, kyaw@gmail.com"
                       style="background-color: #0f172a; border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;"
                       required />
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted">Password</label>
                <input type="password" name="password" class="form-control text-white" style="background-color: #0f172a; border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;" required />
            </div>

            <button type="submit" class="btn btn-primary w-100 fw-bold mb-3" style="border-radius: 10px; background-color: #3b82f6; border: none;">Sign In</button>
            <p class="text-center small text-muted mb-0">Don't have an account? <a asp-action="Register" class="text-primary text-decoration-none fw-semibold">Register here</a></p>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    @if (TempData["LoginFailed"] != null)
    {
        <text>
            <script>
               
                var passwordField = document.querySelector("input[name='password']");
                if (passwordField) {
                    passwordField.value = "";
                }

               
                function closeAlert() {
                    var alertOverlay = document.getElementById("myAlertBox");
                    if (alertOverlay) {
                        alertOverlay.style.display = "none";
                    }
                    if (passwordField) {
                        passwordField.focus();
                    }
                }
            </script>
        </text>
    }

    @if (TempData["RegisterSuccess"] != null)
    {
        <text>
            <script>
                
                function closeRegisterAlert() {
                    var registerAlertOverlay = document.getElementById("myRegisterAlertBox");
                    if (registerAlertOverlay) {
                        registerAlertOverlay.style.display = "none";
                    }
                }
            </script>
        </text>
    }
}