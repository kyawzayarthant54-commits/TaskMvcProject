@{
    ViewData["Title"] = "Data Analytics";
}

<style>
    body {
        background-color: #0f172a !important;
        color: #f1f5f9 !important;
    }

    .analytics-card {
        background-color: #1e293b !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        border-radius: 16px !important;
    }

    .text-muted-custom {
        color: #94a3b8 !important;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container mt-4">

    <div class="mb-4">
        <h4 class="fw-bold m-0 text-white">📊 Task Productivity Analytics</h4>
        <p class="text-muted-custom small m-0">Visualizing your workflow metrics and historical task data.</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card analytics-card p-3 border-0" style="border-left: 5px solid #3b82f6 !important;">
                <small class="text-muted-custom text-uppercase fw-bold small">Total Tasks</small>
                <h3 class="fw-bold m-0 mt-1 text-primary">@ViewBag.TotalTasks</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card analytics-card p-3 border-0" style="border-left: 5px solid #10b981 !important;">
                <small class="text-muted-custom text-uppercase fw-bold small">Completion Rate</small>
                <h3 class="fw-bold m-0 mt-1 text-success">
                    @(ViewBag.TotalTasks > 0 ? (ViewBag.CompletedTasks * 100 / ViewBag.TotalTasks) : 0)%
                </h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card analytics-card p-3 border-0" style="border-left: 5px solid #f59e0b !important;">
                <small class="text-muted-custom text-uppercase fw-bold small">Still Pending</small>
                <h3 class="fw-bold m-0 mt-1 text-warning">@ViewBag.PendingTasks</h3>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-md-6">
            <div class="card analytics-card p-4 shadow-sm h-100">
                <h6 class="fw-bold text-white mb-3">📁 Tasks by Category</h6>
                <div style="position: relative; max-height: 280px; display: flex; justify-content: center;">
                    <canvas id="categoryPieChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card analytics-card p-4 shadow-sm h-100">
                <h6 class="fw-bold text-white mb-3">⚡ Tasks by Priority</h6>
                <div style="position: relative; max-height: 280px;">
                    <canvas id="priorityBarChart"></canvas>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    
    const catLabels = @Html.Raw(Json.Serialize(ViewBag.CategoryLabels));
    const catCounts = @Html.Raw(Json.Serialize(ViewBag.CategoryCounts));

    const priLabels = @Html.Raw(Json.Serialize(ViewBag.PriorityLabels));
    const priCounts = @Html.Raw(Json.Serialize(ViewBag.PriorityCounts));

    
    const ctxPie = document.getElementById('categoryPieChart').getContext('2d');
    new Chart(ctxPie, {
        type: 'pie',
        data: {
            labels: catLabels.length > 0 ? catLabels : ["No Data Available"],
            datasets: [{
                data: catCounts.length > 0 ? catCounts : [1],
                backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#ec4899', '#8b5cf6', '#06b6d4'],
                borderWidth: 2,
                borderColor: '#1e293b'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { color: '#94a3b8', font: { weight: 'bold' } }
                }
            }
        }
    });

    
    const ctxBar = document.getElementById('priorityBarChart').getContext('2d');
    new Chart(ctxBar, {
        type: 'bar',
        data: {
            labels: priLabels.length > 0 ? priLabels : ["No Data"],
            datasets: [{
                label: 'Number of Tasks',
                data: priCounts.length > 0 ? priCounts : [0],
                backgroundColor: '#3b82f6',
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { color: '#94a3b8', stepSize: 1 },
                    grid: { color: 'rgba(255, 255, 255, 0.05)' }
                },
                x: {
                    ticks: { color: '#94a3b8', font: { weight: 'bold' } },
                    grid: { display: false }
                }
            },
            plugins: {
                legend: { display: false } 
            }
        }
    });
</script>