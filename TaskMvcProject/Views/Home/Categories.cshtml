@model IEnumerable<TaskMvcProject.Models.Category>

@{
    ViewData["Title"] = "Manage Categories";
}

<style>
    body {
        background-color: #0f172a !important;
        color: #f1f5f9 !important;
    }

    .category-card {
        background: linear-gradient(145deg, #1e293b, #0f172a);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 15px;
    }

    .category-input {
        background-color: #1e293b !important;
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
        color: #ffffff !important;
        border-radius: 10px;
    }

        .category-input:focus {
            background-color: #1e293b !important;
            color: #ffffff !important;
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25) !important;
        }

    .category-item-box {
        background-color: #1e293b;
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        transition: all 0.2s ease;
    }

        .category-item-box:hover {
            transform: translateY(-2px);
            background-color: #24344d;
        }

    .action-btn {
        font-size: 0.85rem !important;
        padding: 4px 6px !important;
        opacity: 0.6;
        transition: all 0.2s ease;
        text-decoration: none !important;
    }

        .action-btn:hover {
            opacity: 1;
            transform: scale(1.1);
        }
</style>

<div class="container mt-5" style="max-width: 900px;">
    <div class="text-center mb-4">
        <h2 class="fw-bold text-white">📁 Manage Categories</h2>
        <p class="text-muted">Create, update, and organize folders to categorize your current tasks.</p>
    </div>

    <div class="category-card p-4 mb-4 shadow-lg">

        @if (TempData["CategoryDeleteError"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 text-white shadow-sm mb-3" role="alert" style="background-color: #ef4444; border-radius: 8px; font-size: 0.9rem;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @TempData["CategoryDeleteError"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close" style="padding: 1rem; font-size: 0.75rem;"></button>
            </div>
        }

        @if (TempData["CategoryDeleteSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 text-white shadow-sm mb-3" role="alert" style="background-color: #10b981; border-radius: 8px; font-size: 0.9rem;">
                <i class="bi bi-check-circle-fill me-2"></i>
                @TempData["CategoryDeleteSuccess"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close" style="padding: 1rem; font-size: 0.75rem;"></button>
            </div>
        }

        <form asp-action="CreateCategory" method="post" class="row g-2 align-items-center">
            @Html.AntiForgeryToken()
            <div class="col-md-9">
                <input type="text" name="name" class="form-control category-input py-2" placeholder="Enter new category name... (e.g., Personal, Work)" maxlength="20" required />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 fw-bold py-2" style="border-radius: 10px; background-color: #3b82f6; border: none;">+ Add Category</button>
            </div>
        </form>
    </div>

    <div class="row g-3">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-muted text-center py-4">No categories found. Add one above!</div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="col-md-4">
                    <div class="category-item-box p-3 d-flex align-items-center justify-content-between shadow-sm">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-5">📁</span>
                            <span class="fw-semibold text-white">@item.Name</span>
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <button type="button" class="btn btn-link text-warning action-btn" data-bs-toggle="modal" data-bs-target="#editModal-@item.Id" title="Edit">
                                📝
                            </button>

                            <button type="button" class="btn btn-link text-danger action-btn" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.Id" title="Delete">
                                🗑️
                            </button>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="editModal-@item.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content text-white" style="background-color: #1e293b; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
                            <div class="modal-header border-bottom border-secondary">
                                <h5 class="modal-title fw-bold">✏️ Edit Category</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <form asp-action="EditCategory" asp-route-id="@item.Id" method="post">
                                @Html.AntiForgeryToken()
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label text-muted fw-bold">Category Name</label>
                                        <input type="text" name="name" class="form-control text-white" style="background-color: #0f172a; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;" value="@item.Name" maxlength="20" required />
                                    </div>
                                </div>
                                <div class="modal-footer border-top border-secondary">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal" style="border-radius: 8px;">Cancel</button>
                                    <button type="submit" class="btn btn-primary btn-sm" style="background-color: #3b82f6; border: none; border-radius: 8px;">Save Changes</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content text-white" style="background-color: #1e293b; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
                            <div class="modal-header border-bottom border-secondary">
                                <h5 class="modal-title fw-bold text-danger">⚠️ Confirm Delete</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body text-center py-4">
                                <span style="font-size: 3rem;">🗑️</span>
                                <h5 class="mt-3 fw-semibold text-white">တကယ်ပဲ ဖျက်မှာ သေချာပါသလား?</h5>
                                <p class="text-muted mb-0">Category <strong class="text-warning">"@item.Name"</strong> အား ဖျက်သိမ်းရန် သေချာပါသလား။ ဤလုပ်ဆောင်ချက်ကို ပြန်ပြင်၍မရနိုင်ပါ။</p>
                            </div>
                            <div class="modal-footer border-top border-secondary justify-content-center">
                                <button type="button" class="btn btn-secondary px-4 btn-sm" data-bs-dismiss="modal" style="border-radius: 8px;">မဖျက်တော့ပါ</button>
                                <form asp-action="DeleteCategory" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger px-4 btn-sm" style="background-color: #ef4444; border: none; border-radius: 8px;">သေချာသည်၊ ဖျက်မည်</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const alerts = document.querySelectorAll('.alert-dismissible');
            alerts.forEach(function (alert) {
                setTimeout(function () {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 5000);
            });
        });
    </script>
}